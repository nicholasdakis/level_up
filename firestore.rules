rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // request.auth != null requires a valid Firebase Auth token, so the public API key alone is not enough to read data
      allow get, list: if request.auth != null;
      // request.auth.uid == userId ensures even logged-in users cannot write to someone else's document
      allow write: if request.auth != null && request.auth.uid == userId;

      // Only the owner can read or write their own reminders
      match /reminders/{reminderId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Used to fetch the server timestamp for daily reward logic
    match /serverTime/{document} {
      allow read, write: if request.auth != null;
    }
  }
}